          min: currentProduct === 'hero' ? 0 : 50,
          max: currentProduct === 'hero' ? 30 : 100
        }
      }
    }
  });
}

function updatePurityStats() {
  const meta = PROD_META[currentProduct];
  const data = meta.data.annee;
  const all_medians = meta.data.mois.map(d => d.median).filter(v => v != null);
  const all_means = meta.data.mois.map(d => d.mean).filter(v => v != null);
  const totalN = meta.data.annee.reduce((s, d) => s + d.count, 0);
  const globalMedian = [...all_medians].sort((a,b)=>a-b)[Math.floor(all_medians.length/2)];
  const globalMean = all_means.reduce((s,v)=>s+v,0)/all_means.length;
  const color = meta.color;

  document.getElementById('purity-stats').innerHTML = `
    <div class="stat-card">
      <div class="label">n total</div>
      <div class="val" style="color:${color}">${totalN}</div>
      <div class="sub">échantillons</div>
    </div>
    <div class="stat-card">
      <div class="label">Médiane globale</div>
      <div class="val" style="color:${color}">${globalMedian?.toFixed(1)}%</div>
      <div class="sub">sur toute la période</div>
    </div>
    <div class="stat-card">
      <div class="label">Moyenne globale</div>
      <div class="val" style="color:${color}">${globalMean?.toFixed(1)}%</div>
      <div class="sub">mensuelle pondérée</div>
    </div>
  `;
}

