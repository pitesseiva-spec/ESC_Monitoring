function processSamples() {
  const byMonth = {};
  const cats = ['Cocaine HCl', 'Cocaine base', 'Héroïne', 'Autre'];
  RAW.samples_by_month.forEach(r => {
    if (!byMonth[r.mois]) byMonth[r.mois] = {};
    byMonth[r.mois][r.cat] = r.count;
  });
  const months = Object.keys(byMonth).sort();
  const datasets = cats.map(cat => ({
    label: cat,
    data: months.map(m => byMonth[m][cat] || 0),
    backgroundColor: COLORS[cat] + 'cc',
    borderColor: COLORS[cat],
    borderWidth: 1,
    borderRadius: 2
  }));
  return { months, datasets, byMonth };
}

