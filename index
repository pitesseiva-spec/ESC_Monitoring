<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Drug Checking ECS — Tableau de bord</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');

  :root {
    --bg: #0e1117;
    --surface: #161b26;
    --surface2: #1e2536;
    --border: #2a3348;
    --text: #e8eaf0;
    --muted: #6b7594;
    --coke-hcl: #4fc3f7;
    --coke-base: #f06292;
    --hero: #a5d6a7;
    --autre: #ffb74d;
    --accent: #7986cb;
    --tag-bg: #1a2340;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 18px 32px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .header-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--tag-bg);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 3px;
  }
  header h1 {
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--text);
    flex: 1;
  }
  header h1 span {
    color: var(--muted);
    font-weight: 300;
    font-size: 13px;
    margin-left: 12px;
  }

  /* NAV */
  nav {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 32px;
    display: flex;
    gap: 4px;
  }
  nav button {
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    padding: 12px 18px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    letter-spacing: 0.02em;
  }
  nav button:hover { color: var(--text); }
  nav button.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  /* MAIN */
  main { padding: 28px 32px; }

  /* KPI CARDS */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 28px;
  }
  .kpi {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 20px;
  }
  .kpi-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .kpi-label::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--dot-color, var(--accent));
    flex-shrink: 0;
  }
  .kpi-value {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 28px;
    font-weight: 600;
    color: var(--text);
    line-height: 1;
  }
  .kpi-sub {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* VIEWS */
  .view { display: none; }
  .view.active { display: block; }

  /* CHART PANELS */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 16px;
    overflow: hidden;
  }
  .panel-header {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .panel-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .panel-title .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .panel-body {
    padding: 16px 20px;
    position: relative;
  }

  /* CONTROLS */
  .controls {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
  }
  .controls label {
    font-size: 11px;
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .seg-btn {
    background: var(--tag-bg);
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.12s;
    letter-spacing: 0.05em;
  }
  .seg-btn:hover { color: var(--text); border-color: var(--accent); }
  .seg-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  /* LEGEND */
  .legend {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    padding: 10px 20px;
    border-top: 1px solid var(--border);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    color: var(--muted);
  }
  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* STATS ROW */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 16px;
  }
  .stat-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 12px 16px;
  }
  .stat-card .label {
    font-size: 11px;
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
  }
  .stat-card .val {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 20px;
    font-weight: 600;
  }
  .stat-card .sub {
    font-size: 11px;
    color: var(--muted);
    margin-top: 2px;
  }

  /* PURITY SELECTORS */
  .product-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .product-tab {
    padding: 7px 18px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--muted);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.02em;
  }
  .product-tab:hover { border-color: var(--accent); color: var(--text); }
  .product-tab.active {
    color: #fff;
    font-weight: 600;
  }
  .product-tab[data-prod="coke_hcl"].active { background: #1a3a4e; border-color: var(--coke-hcl); color: var(--coke-hcl); }
  .product-tab[data-prod="coke_base"].active { background: #3d1e2a; border-color: var(--coke-base); color: var(--coke-base); }
  .product-tab[data-prod="hero"].active { background: #1e3420; border-color: var(--hero); color: var(--hero); }

  canvas { max-height: 320px; }

  /* TOOLTIP override */
  .tooltip-note {
    font-size: 11px;
    color: var(--muted);
    padding: 6px 20px 12px;
    font-style: italic;
  }

  .grid2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  @media (max-width: 800px) {
    .kpi-grid { grid-template-columns: repeat(2,1fr); }
    .stats-row { grid-template-columns: repeat(2,1fr); }
    .grid2 { grid-template-columns: 1fr; }
    header { padding: 14px 16px; flex-wrap: wrap; }
    main { padding: 16px; }
    nav { padding: 0 8px; }
  }

  /* TABLE */
  .data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
  .data-table th {
    text-align: left;
    padding: 8px 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    background: var(--surface2);
    position: sticky; top: 0;
  }
  .data-table td {
    padding: 7px 12px;
    border-bottom: 1px solid #1a2030;
    color: var(--text);
    vertical-align: top;
  }
  .data-table tr:hover td { background: #1a2336; }
  .data-table td.date { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--muted); white-space: nowrap; }
  .data-table td.purete { font-family: 'IBM Plex Mono', monospace; font-weight: 600; text-align: right; }
  .data-table td.comment { color: var(--muted); font-style: italic; font-size: 11px; }
  .prod-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 2px 8px; border-radius: 3px;
    font-size: 11px; font-weight: 500;
    border: 1px solid;
  }
  .table-wrap { max-height: 420px; overflow-y: auto; border-radius: 0 0 6px 6px; }
  .kpi-grid-sm {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }
</style>
</head>
<body>

<header>
  <div class="header-badge">ECS · Drug Checking</div>
  <h1>Tableau de bord analytique <span>2022–2026</span></h1>
  <div class="header-badge" id="update-badge">n=702</div>
</header>

<nav>
  <button class="active" onclick="showView('echantillons', this)">Échantillons</button>
  <button onclick="showView('purete', this)">Pureté</button>
  <button onclick="showView('autres', this)">Autres substances</button>
</nav>

<main>
  <!-- KPI CARDS -->
  <div class="kpi-grid">
    <div class="kpi">
      <div class="kpi-label" style="--dot-color: var(--coke-hcl)">Cocaïne HCl</div>
      <div class="kpi-value">388</div>
      <div class="kpi-sub">Médiane pureté : 70.4%</div>
    </div>
    <div class="kpi">
      <div class="kpi-label" style="--dot-color: var(--coke-base)">Cocaine base</div>
      <div class="kpi-value">156</div>
      <div class="kpi-sub">Médiane pureté : 81.6%</div>
    </div>
    <div class="kpi">
      <div class="kpi-label" style="--dot-color: var(--hero)">Héroïne</div>
      <div class="kpi-value">115</div>
      <div class="kpi-sub">Médiane pureté : 12.4%</div>
    </div>
    <div class="kpi">
      <div class="kpi-label" style="--dot-color: var(--autre)">Total</div>
      <div class="kpi-value">702</div>
      <div class="kpi-sub">Nov 2022 → Avr 2026</div>
    </div>
  </div>

  <!-- VIEW: ÉCHANTILLONS -->
  <div id="view-echantillons" class="view active">
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">
          <span class="dot" style="background:var(--accent)"></span>
          Volume d'échantillons par mois
        </div>
        <div class="controls">
          <label>Vue :</label>
          <button class="seg-btn active" onclick="setStackMode('stacked', this)">Empilé</button>
          <button class="seg-btn" onclick="setStackMode('grouped', this)">Groupé</button>
        </div>
      </div>
      <div class="panel-body">
        <canvas id="chartSamples"></canvas>
      </div>
      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:var(--coke-hcl)"></div>Cocaïne HCl</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--coke-base)"></div>Cocaine base</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--hero)"></div>Héroïne</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--autre)"></div>Autre</div>
      </div>
    </div>

    <div class="grid2">
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title"><span class="dot" style="background:var(--accent)"></span>Répartition totale</div>
        </div>
        <div class="panel-body">
          <canvas id="chartPie" style="max-height:240px"></canvas>
        </div>
      </div>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title"><span class="dot" style="background:var(--accent)"></span>Volume annuel par produit</div>
        </div>
        <div class="panel-body">
          <canvas id="chartYearly" style="max-height:240px"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- VIEW: PURETÉ -->
  <div id="view-purete" class="view">
    <div class="product-tabs">
      <button class="product-tab active" data-prod="coke_hcl" onclick="selectProduct('coke_hcl', this)">Cocaïne HCl</button>
      <button class="product-tab" data-prod="coke_base" onclick="selectProduct('coke_base', this)">Cocaine base</button>
      <button class="product-tab" data-prod="hero" onclick="selectProduct('hero', this)">Héroïne base</button>
    </div>

    <div class="stats-row" id="purity-stats"></div>

    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">
          <span class="dot" id="purity-dot" style="background:var(--coke-hcl)"></span>
          <span id="purity-title">Cocaïne HCl — Évolution de la pureté</span>
        </div>
        <div class="controls">
          <label>Granularité :</label>
          <button class="seg-btn active" onclick="setGranularity('mois', this)">Mensuel</button>
          <button class="seg-btn" onclick="setGranularity('trimestre', this)">Trimestriel</button>
          <button class="seg-btn" onclick="setGranularity('annee', this)">Annuel</button>
        </div>
      </div>
      <div class="panel-body">
        <canvas id="chartPurity"></canvas>
      </div>
      <div class="tooltip-note">Bande : Q1–Q3 · Ligne pleine : médiane · Ligne pointillée : moyenne</div>
    </div>

    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">
          <span class="dot" id="hist-dot" style="background:var(--coke-hcl)"></span>
          <span id="hist-title">Distribution des puretés</span>
        </div>
      </div>
      <div class="panel-body">
        <canvas id="chartHist" style="max-height:220px"></canvas>
      </div>
    </div>
  </div>

  <!-- VIEW: AUTRES -->
  <div id="view-autres" class="view">
    <div class="kpi-grid-sm">
      <div class="kpi">
        <div class="kpi-label" style="--dot-color:#ffb74d">Total autres</div>
        <div class="kpi-value" style="color:#ffb74d">40</div>
        <div class="kpi-sub">5.7% des échantillons</div>
      </div>
      <div class="kpi">
        <div class="kpi-label" style="--dot-color:#8bc34a">Catégorie principale</div>
        <div class="kpi-value" style="font-size:18px;color:#8bc34a">Cannabis / THC</div>
        <div class="kpi-sub">21 échantillons (53%)</div>
      </div>
      <div class="kpi">
        <div class="kpi-label" style="--dot-color:#ce93d8">Substances distinctes</div>
        <div class="kpi-value" style="color:#ce93d8">15</div>
        <div class="kpi-sub">2023–2026</div>
      </div>
    </div>

    <div class="grid2">
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title"><span class="dot" style="background:#ffb74d"></span>Répartition par substance</div>
        </div>
        <div class="panel-body">
          <canvas id="chartAutresPie" style="max-height:280px"></canvas>
        </div>
      </div>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title"><span class="dot" style="background:#ffb74d"></span>Volume par année</div>
        </div>
        <div class="panel-body">
          <canvas id="chartAutresYear" style="max-height:280px"></canvas>
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-header">
        <div class="panel-title"><span class="dot" style="background:#ffb74d"></span>Détail des échantillons</div>
      </div>
      <div class="table-wrap">
        <table class="data-table" id="autresTable">
          <thead>
            <tr>
              <th>Date</th>
              <th>Substance</th>
              <th>Pureté</th>
              <th>Prix (CHF)</th>
              <th>Commentaire</th>
            </tr>
          </thead>
          <tbody id="autresTbody"></tbody>
        </table>
      </div>
    </div>
  </div>
</main>

