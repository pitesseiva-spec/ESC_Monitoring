function selectProduct(prod, btn) {
  currentProduct = prod;
  document.querySelectorAll('.product-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const meta = PROD_META[prod];
  document.getElementById('purity-dot').style.background = meta.color;
  document.getElementById('purity-title').textContent = meta.label + ' — Évolution de la pureté';
  document.getElementById('hist-dot').style.background = meta.color;
  document.getElementById('hist-title').textContent = meta.label + ' — Distribution des puretés';
  buildPurityChart();
  updatePurityStats();
}

function setGranularity(gran, btn) {
  currentGranularity = gran;
  document.querySelectorAll('.seg-btn').forEach(b => {
    if (b.onclick && b.onclick.toString().includes('setGranularity')) b.classList.remove('active');
  });
  btn.classList.add('active');
  buildPurityChart();
}

function buildPurityCharts() {
  buildPurityChart();
  buildHistogram();
  updatePurityStats();
}

function buildPurityChart() {
  const meta = PROD_META[currentProduct];
  const rawData = meta.data[currentGranularity];
  const labelKey = currentGranularity;
  const labels = rawData.map(d => d[labelKey]);
  const medians = rawData.map(d => d.median);
  const means = rawData.map(d => d.mean);
  const q25 = rawData.map(d => d.q25);
  const q75 = rawData.map(d => d.q75);

  // Band dataset: fill between Q1 and Q3
  // We'll use a custom approach: draw filled area using two datasets
  destroyChart('chartPurity');
  const ctx = document.getElementById('chartPurity').getContext('2d');

  const color = meta.color;
  const hexToRgb = h => { const r = parseInt(h.slice(1,3),16), g = parseInt(h.slice(3,5),16), b = parseInt(h.slice(5,7),16); return `${r},${g},${b}`; };
  const rgb = hexToRgb(color);

  charts.chartPurity = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Q75',
          data: q75,
          fill: '+1',
          backgroundColor: `rgba(${rgb},0.12)`,
          borderColor: 'transparent',
          pointRadius: 0,
          tension: 0.3
        },
        {
          label: 'Q25',
          data: q25,
          fill: false,
          borderColor: 'transparent',
          backgroundColor: 'transparent',
          pointRadius: 0,
          tension: 0.3
        },
        {
          label: 'Médiane',
          data: medians,
          fill: false,
          borderColor: color,
          borderWidth: 2.5,
          pointBackgroundColor: color,
          pointRadius: rawData.map(d => d.count < 5 ? 4 : 3),
          pointHoverRadius: 7,
          tension: 0.3,
          spanGaps: true
        },
        {
          label: 'Moyenne',
          data: means,
          fill: false,
          borderColor: color,
          borderWidth: 1.5,
          borderDash: [5, 4],
          pointRadius: 0,
          pointHoverRadius: 5,
          tension: 0.3,
          spanGaps: true
        }
      ]
    },
    options: {
      ...CHART_DEFAULTS,
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        ...CHART_DEFAULTS.plugins,
        tooltip: {
          ...CHART_DEFAULTS.plugins.tooltip,
          callbacks: {
            title: items => items[0].label,
            label: item => {
              if (item.datasetIndex === 0) return ` Q3: ${item.raw?.toFixed(1)}%`;
              if (item.datasetIndex === 1) return ` Q1: ${item.raw?.toFixed(1)}%`;
              if (item.datasetIndex === 2) return ` Médiane: ${item.raw?.toFixed(1)}%  ·  n=${rawData[item.dataIndex]?.count}`;
              if (item.datasetIndex === 3) return ` Moyenne: ${item.raw?.toFixed(1)}%`;
              return '';
            }
          }
        }
      },
      scales: {
        x: { ...CHART_DEFAULTS.scales.x },
        y: {
          ...CHART_DEFAULTS.scales.y,
          title: { display: true, text: 'Pureté (%)', color: '#6b7594', font: { size: 10 } },
          min: currentProduct === 'hero' ? 0 : 20,
          max: currentProduct === 'hero' ? 50 : 100
        }
      }
    }
  });
  buildHistogram();
}

function buildHistogram() {
  const meta = PROD_META[currentProduct];
  const gran = 'annee';
  const rawData = meta.data[gran];
  const labels = rawData.map(d => d.annee);
  const color = meta.color;

  destroyChart('chartHist');
  const ctx2 = document.getElementById('chartHist').getContext('2d');
  charts.chartHist = new Chart(ctx2, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        {
          label: 'Médiane',
          data: rawData.map(d => d.median),
          backgroundColor: color + '99',
          borderColor: color,
          borderWidth: 1.5,
          borderRadius: 3,
          order: 2
        },
        {
          label: 'Moyenne',
          data: rawData.map(d => d.mean),
          type: 'line',
          borderColor: color,
          borderWidth: 2,
          borderDash: [4, 3],
          pointRadius: 4,
          fill: false,
          order: 1,
          spanGaps: true
        }
      ]
    },
    options: {
      ...CHART_DEFAULTS,
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        ...CHART_DEFAULTS.plugins,
        tooltip: {
          ...CHART_DEFAULTS.plugins.tooltip,
          callbacks: {
            label: item => {
              if (item.datasetIndex === 0) return ` Médiane: ${item.raw?.toFixed(1)}%  ·  n=${rawData[item.dataIndex]?.count}`;
              return ` Moyenne: ${item.raw?.toFixed(1)}%`;
            }
          }
        }
      },
      scales: {
        x: { ...CHART_DEFAULTS.scales.x },
        y: {
          ...CHART_DEFAULTS.scales.y,
