// ============================================================
function setStackMode(mode, btn) {
  stackMode = mode;
  document.querySelectorAll('.seg-btn').forEach(b => {
    if (b.onclick.toString().includes('setStackMode')) b.classList.remove('active');
  });
  btn.classList.add('active');
  if (charts.chartSamples) {
    charts.chartSamples.options.scales.x.stacked = mode === 'stacked';
    charts.chartSamples.options.scales.y.stacked = mode === 'stacked';
    charts.chartSamples.update();
  }
}

