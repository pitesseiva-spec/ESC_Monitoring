let RAW = null;

function updateHeaderStats() {
  const total = RAW.totals.total_samples;
  document.getElementById('update-badge').textContent = `n=${total}`;
  document.querySelector('.kpi-grid .kpi:nth-child(1) .kpi-value').textContent = RAW.totals.coke_hcl;
  document.querySelector('.kpi-grid .kpi:nth-child(2) .kpi-value').textContent = RAW.totals.coke_base;
  document.querySelector('.kpi-grid .kpi:nth-child(3) .kpi-value').textContent = RAW.totals.hero;
  document.querySelector('.kpi-grid .kpi:nth-child(4) .kpi-value').textContent = total;
  if (RAW.last_updated) {
    const d = new Date(RAW.last_updated);
    document.querySelector('.kpi-grid .kpi:nth-child(4) .kpi-sub').textContent =
      `Màj ${d.toLocaleDateString('fr-CH')} ${d.toLocaleTimeString('fr-CH',{hour:'2-digit',minute:'2-digit'})}`;
  }
  // Reconstruire PROD_META avec données fraîches
  PROD_META.coke_hcl.data = RAW.purity_coke_hcl;
  PROD_META.coke_base.data = RAW.purity_coke_base;
  PROD_META.hero.data = RAW.purity_hero;
}

async function loadData() {
  try {
    if (API_URL) {
      const res = await fetch(API_URL);
      RAW = await res.json();
    } else {
      RAW = RAW_STATIC;
    }
  } catch(e) {
    console.warn('API indisponible, données statiques utilisées:', e);
    RAW = RAW_STATIC;
  }
  updateHeaderStats();
  buildSamplesCharts();
}

